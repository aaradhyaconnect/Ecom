# ============================================
# Arcon Style — Environment Variables
# ============================================
# Copy this file to .env.local and fill in real values.

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Arcon Style"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Razorpay (optional — if using Razorpay)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_API_URL=https://sandbox.cashfree.com/pg
NEXT_PUBLIC_CASHFREE_MODE=production

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_API_URL=https://apiv2.shiprocket.in/v1/external

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare R2 (image storage)
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# Resend (transactional emails)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=orders@arconstyle.com

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=9151281593

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Sentry (error tracking — optional but recommended)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Push Notifications (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Admin
ADMIN_SECRET_KEY=your_admin_secret_key_for_initial_setup
